# ─── ReplyAI environment template ─────────────────────────────────
# Copy to server/.env (server) and client/.env (client). NEVER commit real values.
# Production values live in: Vercel project settings (both client & server projects).

# ── SERVER (server/.env) ──────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
GEMINI_API_KEY=AIza...
GROQ_API_KEY=
# Free Groq backup: https://console.groq.com (14,400 req/day, llama-3.3-70b)

# Firebase Admin — paste the WHOLE service-account JSON on one line:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Paystack
PAYSTACK_SECRET_KEY=sk_live_...
# Flutterwave (USD/global)
FLW_PUBLIC_KEY=FLWPUBK_LIVE-...
FLW_SECRET_KEY=FLWSECK_LIVE-...
FLW_SECRET_HASH=your_random_webhook_secret

CLIENT_URL=https://replyai.com.ng
PORT=4000
NODE_ENV=production

# ── CLIENT (client/.env) ──────────────────────────────────────────
VITE_API_URL=https://api.replyai.com.ng
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_PAYSTACK_PUBLIC_KEY=pk_live_...
VITE_FLW_PUBLIC_KEY=FLWPUBK_LIVE-...
